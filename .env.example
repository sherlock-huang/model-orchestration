# Environment Variables for Model Orchestration Platform

# Server
PORT=3000
NODE_ENV=development

# OpenAI API Key (for GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek API Key (for DeepSeek models)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Optional: Custom API Endpoints (for local models or proxies)
# OPENAI_API_BASE=https://api.openai.com/v1
# ANTHROPIC_API_BASE=https://api.anthropic.com

# Optional: Model Aliases
# DEFAULT_MODEL=gpt-4
# ANALYZER_MODEL=claude-3.5-sonnet
# AGGREGATOR_MODEL=gpt-4o
