# 模型配置

# 必需的 API Keys（至少配置一个）
KIMI_API_KEY=your-kimi-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
ARK_CODE_API_KEY=your-ark-code-api-key-here

# 可选：自定义模型名称（默认值已填）
KIMI_MODEL_NAME=kimi-pro
MINIMAX_MODEL_NAME=minimax-abab6.5s-chat
ARK_CODE_MODEL_NAME=volcengine-plan/ark-code-latest

# 可选：自定义 API 端点（默认值已填）
KIMI_API_ENDPOINT=https://api.moonshot.cn/v1
MINIMAX_API_ENDPOINT=https://api.minimax.chat/v1
ARK_CODE_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# 兼容旧配置（可选）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ===== 高级配置：JSON 方式（优先级更高）=====
# 如果需要更灵活的模型配置，可以使用 JSON 格式
